# ─────────────────────────────────────────────────────────────────
# Larry's Flashcards — environment variables
# ─────────────────────────────────────────────────────────────────
#
# HOW TO USE
# ──────────
# 1. Copy this file:   cp .env.example .env.local
# 2. Fill in the values below (see README.md for where to find them)
# 3. Restart the dev server:  npm run dev
#
# .env.local is in .gitignore — your secrets will never be committed.
# This file (.env.example) IS committed — keep it secret-free.
# ─────────────────────────────────────────────────────────────────


# ── Supabase project URL ──────────────────────────────────────────
# Supabase Dashboard → Project Settings → API → Project URL
# Safe to expose to the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co


# ── Supabase anon / public key ────────────────────────────────────
# Supabase Dashboard → Project Settings → API → Project API keys → anon public
# Safe to expose to the browser (NEXT_PUBLIC_).
# This key is controlled by your Row Level Security policies — keep RLS tight.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here


# ── Supabase service role key ─────────────────────────────────────
# Supabase Dashboard → Project Settings → API → Project API keys → service_role secret
#
# ⚠️  DANGER — this key bypasses ALL Row Level Security.
#     • Never use it in client components or anywhere the browser can reach.
#     • Only import lib/supabase/admin.ts inside Server Actions or API Routes.
#     • Never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── Site URL ──────────────────────────────────────────────────────
# The canonical public URL of this deployment.
# Local:       http://localhost:3000
# Production:  https://your-app.vercel.app  (or your custom domain)
# Used by Supabase Auth redirect URLs (e.g. email confirmation links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
